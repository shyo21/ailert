{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "ailert",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-20",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"triggers": {
		"crons": [
			"*/2 * * * *"
		]
	},
	"kv_namespaces": [
		{
			"binding": "STATUS_STORE",
			"id": "1a75df77ce4f44c081d20d831f238003"
		}
	]
}